{
  "info": {
    "_postman_id": "car-price-api-collection",
    "name": "Car Price API",
    "description": "FastAPI serving layer for car_price_model@Champion.\n\nImport Local.postman_environment.json and select **Car Price API — Local**.\n\n**baseUrl must be** `http://localhost:8000` **with NO trailing slash** (not `http://localhost:8000/`).\n\nKIND: run `kubectl port-forward service/car-price-api 8000:8000` first.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8000"
    },
    {
      "key": "recordId",
      "value": "REPLACE_WITH_ID_FROM_HISTORY"
    }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "GET /",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/"
          }
        },
        {
          "name": "GET /health",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/health"
          }
        },
        {
          "name": "GET /ready",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/ready"
          }
        }
      ]
    },
    {
      "name": "Predict",
      "item": [
        {
          "name": "POST /predict/single",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"brand\": \"Toyota\",\n  \"model\": \"Yaris\",\n  \"year\": 2019,\n  \"transmission\": \"Manual\",\n  \"mileage\": 25000,\n  \"fuelType\": \"Petrol\",\n  \"tax\": 145,\n  \"mpg\": 55,\n  \"engineSize\": 1.5,\n  \"previousOwners\": 1,\n  \"paintQuality\": 85,\n  \"hasDamage\": 0\n}"
            },
            "url": "{{baseUrl}}/predict/single"
          }
        },
        {
          "name": "POST /predict (batch)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"cars\": [\n    {\n      \"brand\": \"Toyota\",\n      \"model\": \"Yaris\",\n      \"year\": 2019,\n      \"transmission\": \"Manual\",\n      \"mileage\": 25000,\n      \"fuelType\": \"Petrol\",\n      \"tax\": 145,\n      \"mpg\": 55,\n      \"engineSize\": 1.5,\n      \"previousOwners\": 1,\n      \"paintQuality\": 85,\n      \"hasDamage\": 0\n    },\n    {\n      \"brand\": \"BMW\",\n      \"model\": \"3 Series\",\n      \"year\": 2018,\n      \"transmission\": \"Automatic\",\n      \"mileage\": 45000,\n      \"fuelType\": \"Diesel\",\n      \"tax\": 150,\n      \"mpg\": 50,\n      \"engineSize\": 2.0,\n      \"previousOwners\": 2,\n      \"paintQuality\": 75,\n      \"hasDamage\": 0\n    }\n  ]\n}"
            },
            "url": "{{baseUrl}}/predict"
          }
        }
      ]
    },
    {
      "name": "Prediction history",
      "item": [
        {
          "name": "GET /predictions/history",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/predictions/history"
          }
        },
        {
          "name": "GET /predictions/history?limit=10",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/predictions/history?limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["predictions", "history"],
              "query": [
                {
                  "key": "limit",
                  "value": "10"
                }
              ]
            }
          }
        },
        {
          "name": "GET /predictions/history/{id}",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/predictions/history/{{recordId}}"
          }
        }
      ]
    }
  ]
}
